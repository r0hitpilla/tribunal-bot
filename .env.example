# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord application/client ID from https://discord.com/developers/applications
DISCORD_CLIENT_ID=

# Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Tracker.gg API key from https://tracker.gg/developers/apps (used for Valorant)
TRACKER_API_KEY=

# Steam Web API key from https://steamcommunity.com/dev/apikey (used for CS2)
STEAM_API_KEY=

# The channel ID where weekly shame reports are posted (#tribunal channel)
# Right-click channel → Copy Channel ID (enable Developer Mode in Discord settings first)
TRIBUNAL_CHANNEL_ID=

# Path where tribunal.db is stored — set to your Railway volume mount path on Railway
# Leave blank locally (defaults to ./data/)
DATA_DIR=
